<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="500.0" prefWidth="700.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f2027, #203a43, #2c5364);"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.association.messagerieg2.client.ChatController">

    <!-- TITRE -->
    <top>
        <Label alignment="CENTER" prefHeight="40.0" prefWidth="700.0"
               text="Messagerie" textFill="WHITE"
               BorderPane.alignment="CENTER">
            <font><Font name="System Bold" size="22.0" /></font>
        </Label>
    </top>

    <!-- LISTE MEMBRES GAUCHE -->
    <left>
        <VBox prefWidth="160.0" style="-fx-background-color: rgba(255,255,255,0.05);"
              BorderPane.alignment="CENTER">
            <Label alignment="CENTER" prefHeight="28.0" prefWidth="160.0"
                   text="Membres" textFill="WHITE"
                   style="-fx-font-size: 13; -fx-padding: 5 0 5 0;" />
            <ListView fx:id="userListView" VBox.vgrow="ALWAYS" prefWidth="160.0" />
        </VBox>
    </left>

    <!-- ZONE CHAT CENTRE -->
    <center>
        <VBox BorderPane.alignment="CENTER">

            <!-- HEADER nom + statut -->
            <HBox fx:id="chatHeader" prefHeight="36.0"
                  style="-fx-background-color: rgba(255,255,255,0.15); -fx-padding: 6 12; -fx-spacing: 8;"
                  alignment="CENTER_LEFT">
                <Label fx:id="receiverNameLabel" text="Sélectionnez un membre" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="receiverStatusLabel" text="" textFill="#aaaaaa">
                    <font><Font size="11.0" /></font>
                </Label>
            </HBox>

            <!-- MESSAGES -->
            <ScrollPane fx:id="message" VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-padding: 5;">
                <content>
                    <VBox fx:id="messageContainer" prefWidth="520.0"
                          style="-fx-padding: 10; -fx-spacing: 6; -fx-background-color: rgba(255,255,255,0.05)" />
                </content>
            </ScrollPane>

            <!-- BARRE ENVOI -->
            <HBox prefHeight="50.0"
                  style="-fx-spacing: 8; -fx-padding: 6 8; -fx-background-color: rgba(255,255,255,0.08);"
                  alignment="CENTER">
                <Button fx:id="fileButton" mnemonicParsing="false" onAction="#handleFile"
                        prefHeight="35.0" prefWidth="75.0"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-font-size: 11;"
                        text="Fichier" />
                <TextField fx:id="messageField" prefHeight="35.0" HBox.hgrow="ALWAYS"
                           promptText="Écrivez un message..."
                           style="-fx-padding: 0 10; -fx-background-color: white; -fx-font-size: 12; -fx-background-radius: 8;" />
                <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSend"
                        prefHeight="35.0" prefWidth="75.0"
                        style="-fx-background-color: #2c5364; -fx-text-fill: white; -fx-font-size: 12; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="Envoyer" />
            </HBox>

        </VBox>
    </center>

</BorderPane>