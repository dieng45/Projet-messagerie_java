<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #1a1a2e;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.association.messagerieg2.client.ChatController">

    <!-- TOPBAR -->
    <top>
        <HBox prefHeight="50.0" prefWidth="900.0"
              style="-fx-background-color: #16213e; -fx-padding: 0 20; -fx-spacing: 12;"
              alignment="CENTER_LEFT">

            <!-- Logo G2 -->
            <Label text="G2" textFill="WHITE"
                   style="-fx-background-color: #533483; -fx-background-radius: 20; -fx-padding: 4 10; -fx-font-weight: bold; -fx-font-size: 13;"/>

            <!-- Titre — pousse le bouton à droite -->
            <Label text="Messagerie Associations" textFill="WHITE"
                   style="-fx-font-size: 14; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS"/>

            <!-- Bouton Déconnexion — RG4 -->
            <Button fx:id="btnDeconnexion" text="⏻  Déconnexion"
                    onAction="#handleDeconnexion"
                    style="-fx-background-color:#533483;
                           -fx-text-fill: white;
                           -fx-font-size: 11;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-padding: 6 14;"/>
        </HBox>
    </top>

    <!-- SIDEBAR GAUCHE -->
    <left>
        <VBox prefWidth="220.0"
              style="-fx-background-color: #0d1117; -fx-border-color: #21262d; -fx-border-width: 0 1 0 0;"
              BorderPane.alignment="CENTER">

            <!-- Titre sidebar -->
            <Label text="MEMBRES CONNECTÉS"
                   prefWidth="220.0" prefHeight="35.0"
                   textFill="#8892b0"
                   style="-fx-font-size: 11; -fx-padding: 10 12 5 12; -fx-border-color: #21262d; -fx-border-width: 0 0 1 0;"/>

            <!-- Liste membres -->
            <ListView fx:id="userListView" VBox.vgrow="ALWAYS" prefWidth="220.0"
                      style="-fx-background-color: transparent;
                             -fx-border-color: transparent;
                             -fx-control-inner-background: transparent;
                             -fx-padding: 5;"/>
        </VBox>
    </left>

    <!-- ZONE CHAT -->
    <center>
        <VBox BorderPane.alignment="CENTER"
              style="-fx-background-color: #1a1a2e;">

            <!-- HEADER destinataire -->
            <HBox fx:id="chatHeader" prefHeight="50.0"
                  style="-fx-background-color: #161b22;
                         -fx-padding: 8 16;
                         -fx-spacing: 10;
                         -fx-border-color: #21262d;
                         -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT">
                <!-- Avatar cercle -->
                <Label fx:id="avatarLabel" text="?"
                       style="-fx-background-color: #533483;
                              -fx-background-radius: 20;
                              -fx-min-width: 36;
                              -fx-min-height: 36;
                              -fx-max-width: 36;
                              -fx-max-height: 36;
                              -fx-alignment: center;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-font-size: 13;"/>
                <VBox spacing="2">
                    <Label fx:id="receiverNameLabel" text="Sélectionnez un membre"
                           textFill="WHITE"
                           style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Label fx:id="receiverStatusLabel" text=""
                           textFill="#3fb950"
                           style="-fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <!-- MESSAGES -->
            <ScrollPane fx:id="message" VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background-color: transparent;
                               -fx-background: #1a1a2e;
                               -fx-padding: 10;">
                <content>
                    <VBox fx:id="messageContainer" prefWidth="650.0"
                          style="-fx-padding: 10; -fx-spacing: 8; -fx-background-color: #1a1a2e;"/>
                </content>
            </ScrollPane>

            <!-- BARRE ENVOI -->
            <HBox prefHeight="55.0"
                  style="-fx-spacing: 10;
                         -fx-padding: 8 12;
                         -fx-background-color: #0d1117;
                         -fx-border-color: #21262d;
                         -fx-border-width: 1 0 0 0;"
                  alignment="CENTER">
                <Button fx:id="fileButton" mnemonicParsing="false" onAction="#handleFile"
                        prefHeight="38.0" prefWidth="80.0"
                        style="-fx-background-color: #21262d;
                               -fx-text-fill: white;
                               -fx-background-radius: 8;
                               -fx-font-size: 11;
                               -fx-cursor: hand;"
                        text="Fichier"/>
                <TextField fx:id="messageField" prefHeight="38.0" HBox.hgrow="ALWAYS"
                           promptText="Écrire un message... (max 1000 caractères)"
                           style="-fx-background-color: #161b22;
                                  -fx-text-fill: #ccd6f6;
                                  -fx-prompt-text-fill: #484f58;
                                  -fx-background-radius: 22;
                                  -fx-border-radius: 22;
                                  -fx-border-color: #30363d;
                                  -fx-font-size: 12;
                                  -fx-padding: 0 16;"/>
                <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSend"
                        prefHeight="38.0" prefWidth="38.0"
                        style="-fx-background-color: #533483;
                               -fx-text-fill: white;
                               -fx-background-radius: 20;
                               -fx-font-size: 14;
                               -fx-cursor: hand;"
                        text="➤"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>